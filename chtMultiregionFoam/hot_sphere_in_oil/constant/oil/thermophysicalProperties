FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       polynomial;
    thermo          hPolynomial;
    equationOfState icoPolynomial;
    specie          specie;
    energy          sensibleEnthalpy;
}


mixture
{
    // coefficients for oil

    specie
    {
        molWeight       166.0;
    }
    equationOfState
    {
        rhoCoeffs<8>    ( 1076.5 -0.8357 0.0003 -2e-6 0 0 0 0 );
    }
    thermodynamics
    {
        Hf              0;
        Sf              0;
        CpCoeffs<8>     ( 1518.9 2.6074 0.0037 -2e-5 3e-8 0 0 0 );
    }
    transport
    {
        muCoeffs<8>     ( 0.001 0 0 0 0 0 0 0 );
        kappaCoeffs<8>  ( 0.58  0 0 0 0 0 0 0 );
    }
}

