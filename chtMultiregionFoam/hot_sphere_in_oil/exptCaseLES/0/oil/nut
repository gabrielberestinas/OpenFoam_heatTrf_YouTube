dimensions      [ 0 2 -1 0 0 0 0 ];

internalField   uniform 0;

boundaryField
{
    maxY
    {
        type            zeroGradient;
        value           uniform 0;
    }
    minX
    {
        type            zeroGradient;
        value           uniform 0;
    }
    maxX
    {
        type            zeroGradient;
        value           uniform 0;
    }
    minY
    {
        type            zeroGradient;
        value           uniform 0;
    }
    minZ
    {
        type            zeroGradient;
        value           uniform 0;
    }
    maxZ
    {
        type            zeroGradient;
        value           uniform 0;
    }
    oil_to_sphere
    {
        type            zeroGradient;
        value           uniform 0;
    }
}


