FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0/sphere";
    object      T;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [ 0 0 0 1 0 0 0 ];

internalField   uniform 400;

boundaryField
{
    sphere_to_oil
    {
        type            compressible::turbulentTemperatureCoupledBaffleMixed;
        value           uniform 400;
        Tnbr            T;
        kappaMethod     solidThermo;
    }
}

sphere_to_oil
{
    type            calculated;
    value           uniform 100000;
}


