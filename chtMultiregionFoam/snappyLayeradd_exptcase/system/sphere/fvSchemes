FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system/sphere";
    object      fvSchemes;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

ddtSchemes
{
    default         CrankNicolson 0.9;
}

gradSchemes
{
    default         cellMDLimited Gauss linear 1;
}

divSchemes
{
    default         none;
}

laplacianSchemes
{
    default             none;
    laplacian(alpha,h)  Gauss cubic limited 1;
}

interpolationSchemes
{
    default         linear;
}

snGradSchemes
{
    default         limited corrected 0;
}

